# ===========================
# CoinMarket Data 환경변수
# ===========================

# Database (coinmarket-data가 postgres 컨테이너 소유)
# Docker 내부: trader-postgres (컨테이너명)
# 로컬 개발:  localhost
DATABASE_URL=postgresql+asyncpg://trader:trader_password_123@trader-postgres:5432/trader_db

# Coincheck Public API
COINCHECK_BASE_URL=https://coincheck.com
COINCHECK_WS_URL=wss://ws-api.coincheck.com/

# Coincheck WS 구독 페어 (쉼표 구분, 공백 없음)
CK_WS_PAIRS=btc_jpy,eth_jpy,xrp_jpy

# BitFlyer Public API
BITFLYER_BASE_URL=https://api.bitflyer.com
BITFLYER_WS_URL=wss://ws.lightstream.bitflyer.com/json-rpc
BITFLYER_PRODUCT_CODE=BTC_JPY

# BitFlyer WS 구독 상품 (쉼표 구분, 공백 없음)
BF_WS_PRODUCTS=BTC_JPY,ETH_JPY,XRP_JPY

# WebSocket 설정
WS_WINDOW_SEC=30
WS_MAX_TRADES=1000
WS_RECONNECT_MAX_DELAY=30

# 로깅
LOG_LEVEL=info
TZ=Asia/Tokyo
